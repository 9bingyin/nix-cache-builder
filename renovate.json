{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": ["config:recommended"],
  "timezone": "Asia/Shanghai",
  "nix": {
    "enabled": true
  },
  "lockFileMaintenance": {
    "enabled": true,
    "schedule": ["before 5am every day"]
  },
  "packageRules": [
    {
      "matchManagers": ["nix"],
      "groupName": "nix flake inputs",
      "commitMessageTopic": "nix flake inputs"
    }
  ]
}
